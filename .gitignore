# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local tool state
.codex
.crush/

# OS/editor noise
.DS_Store

# Memoid state and development workspace
.memoid/
.feature-triage/

# Memoid Workspace Isolation
# Ignore all dynamically generated knowledge, but keep the template files
/memory/wiki/*
!/memory/wiki/IDENTITY.md
!/memory/wiki/ESSENTIAL_STORY.md
!/memory/wiki/INDEX.md
!/memory/wiki/LOG.md

/memory/agents/*/*
!/memory/agents/*/IDENTITY.md
!/memory/agents/*/DIARY.md
!/memory/agents/*/PATTERNS.md

# Ignore all evidence and raw data (keep the directory structure)
/memory/evidence/*/*
/memory/raw/*/*
