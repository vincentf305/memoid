#!/usr/bin/env bash
set -euo pipefail

# Memoid CLI Dispatcher
# Simplified for Unified Brain model.

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  LINK_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_TARGET="$(readlink "$SOURCE_PATH")"
  if [[ "$SOURCE_TARGET" != /* ]]; then
    SOURCE_PATH="$LINK_DIR/$SOURCE_TARGET"
  else
    SOURCE_PATH="$SOURCE_TARGET"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

show_help() {
  printf "Usage: memoid <agent> [args...]\n"
  printf "       memoid mcp\n"
  printf "       memoid version\n"
  printf "       memoid init\n"
  printf "       memoid update\n"
  printf "Example: memoid agy\n"
  exit 1
}

if [[ $# -lt 1 ]]; then
  show_help
fi

# Handle version command
if [[ "$1" == "version" ]]; then
  cd "$ROOT_DIR"
  VERSION=$(git describe --tags --always 2>/dev/null || echo "untagged")
  printf "Memoid version: %s\n" "$VERSION"
  exit 0
fi

# Handle init command
if [[ "$1" == "init" ]]; then
  cd "$ROOT_DIR"
  uv sync
  uv run python scripts/post_init_check.py
  exit 0
fi

# Handle update command
if [[ "$1" == "update" ]]; then
  cd "$ROOT_DIR"
  printf "Updating Memoid...\n"
  git fetch --tags --prune
  
  # Get latest tag
  LATEST_TAG=$(git tag --sort=-v:refname | head -n 1)
  
  if [[ -n "$LATEST_TAG" ]]; then
    printf "Switching to latest tag: %s\n" "$LATEST_TAG"
    git checkout "$LATEST_TAG"
  else
    printf "No tags found, pulling latest from main...\n"
    git pull --ff-only
  fi
  
  uv sync
  uv run python scripts/post_init_check.py
  printf "Memoid updated successfully.\n"
  exit 0
fi

# Handle mcp command
if [[ "$1" == "mcp" ]]; then
  shift
  cd "$ROOT_DIR"
  exec uv run --quiet python scripts/mcp_server.py "$@"
fi

AGENT_CMD="$1"
shift

if ! command -v "$AGENT_CMD" >/dev/null 2>&1; then
  printf "Error: Agent command '%s' not found in PATH\n" "$AGENT_CMD" >&2
  printf "Current PATH: %s\n" "$PATH" >&2
  exit 1
fi

# Execute agent command from the Memoid repository root
cd "$ROOT_DIR"
exec "$AGENT_CMD" "$@"
